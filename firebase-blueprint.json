{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a marketplace user, could be a Buyer, Seller, or Admin.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "description": "User email address" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"], "description": "Role-based access system" },
        "username": { "type": "string", "description": "Display name of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when user was created" },
        "status": { "type": "string", "enum": ["active", "pending_approval", "rejected"], "description": "Vendor approval status or account status" },
        "sellerName": { "type": "string", "description": "Store name for sellers" },
        "sellerDescription": { "type": "string", "description": "Store bio or description" },
        "earnings": { "type": "number", "description": "Total trackable earnings for sellers" }
      },
      "required": ["uid", "email", "role", "username", "createdAt", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Product listed for sale by a Seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product title" },
        "description": { "type": "string", "description": "Product details" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Product category" },
        "imageUrls": { "type": "array", "description": "URLs of product photos" },
        "stock": { "type": "number", "description": "Available stock quantity" },
        "sellerId": { "type": "string", "description": "UID of the vendor selling this product" },
        "sellerName": { "type": "string", "description": "Name of the vendor store" },
        "averageRating": { "type": "number", "description": "Average user rating" },
        "reviewCount": { "type": "number", "description": "Number of reviews submitted" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "name", "description", "price", "category", "imageUrls", "stock", "sellerId", "sellerName", "averageRating", "reviewCount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order transaction created by a Buyer.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "buyerId": { "type": "string", "description": "UID of the buyer" },
        "buyerEmail": { "type": "string", "description": "Email of the buyer" },
        "items": { "type": "array", "description": "List of ordered items detailing productId, name, price, quantity, sellerId" },
        "totalAmount": { "type": "number", "description": "Total payment amount including discounts" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"], "description": "Status of the payment transaction" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered"], "description": "Fulfillment status of the order" },
        "shippingAddress": { "type": "string", "description": "Shipping info for delivery" },
        "couponCode": { "type": "string", "description": "Discount coupon applied if any" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when status was updated" }
      },
      "required": ["id", "buyerId", "buyerEmail", "items", "totalAmount", "paymentStatus", "status", "shippingAddress", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product rating and feedback details written by a Buyer.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique review ID" },
        "productId": { "type": "string", "description": "Target product ID" },
        "rating": { "type": "number", "description": "Rating out of 5 stars" },
        "comment": { "type": "string", "description": "Buyers review comments" },
        "buyerId": { "type": "string", "description": "UID of reviewer" },
        "buyerName": { "type": "string", "description": "Reviewer screen name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of review" }
      },
      "required": ["id", "productId", "rating", "comment", "buyerId", "buyerName", "createdAt"]
    },
    "ChatThread": {
      "title": "ChatThread",
      "description": "A conversation channel between a Buyer and a Seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique channel ID, usually combining buyerId and sellerId" },
        "buyerId": { "type": "string", "description": "UID of the buyer" },
        "buyerName": { "type": "string", "description": "Name of the buyer" },
        "sellerId": { "type": "string", "description": "UID of the seller" },
        "sellerName": { "type": "string", "description": "Name of the seller" },
        "lastMessage": { "type": "string", "description": "Content preview of the last message" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of the last activity" }
      },
      "required": ["id", "buyerId", "buyerName", "sellerId", "sellerName", "lastMessage", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "An individual message within a ChatThread.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID" },
        "senderId": { "type": "string", "description": "UID of sender" },
        "senderName": { "type": "string", "description": "Display name of sender" },
        "text": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Sent timestamp" }
      },
      "required": ["id", "senderId", "senderName", "text", "createdAt"]
    },
    "DiscountCoupon": {
      "title": "DiscountCoupon",
      "description": "Marketplace promo code.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Coupon code string (e.g. SAVE10)" },
        "discountPercent": { "type": "number", "description": "Percent discount to apply" },
        "active": { "type": "boolean", "description": "If coupon is active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of coupon addition" }
      },
      "required": ["id", "discountPercent", "active", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection, tracking identity and platform roles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog entries."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Transactional marketplace order documentation."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product feedback and stars database."
    },
    "/chats/{chatId}": {
      "schema": "ChatThread",
      "description": "Active thread information for inter-user messages."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chronological dialog database under a specific thread."
    },
    "/coupons/{couponId}": {
      "schema": "DiscountCoupon",
      "description": "Active promotional system configuration docs."
    }
  }
}
