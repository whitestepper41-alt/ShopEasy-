rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // 2. Products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // 3. Orders collection
    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }

    // 4. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    // 5. Chats & Messages
    match /chats/{chatId} {
      allow read: if true;
      allow write: if true;

      match /messages/{messageId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // 6. Discount Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if true;
    }

    // 7. System Diagnostic Checks
    match /test_operations/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
